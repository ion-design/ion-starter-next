{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["copilot"],
  "permission": {
    "bash": {
      "rm -rf*": "deny",
      "git reset --hard*": "deny",
      "git clean -fd*": "deny",
      "*": "allow"
    },
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": "allow"
  },
  "mcp": {
    "image-tools": {
      "type": "local",
      "command": ["env", "bunx", "tsx", ".opencode/mcp/image-tools/index.ts"]
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=${EXA_API_KEY}&tools=web_search_advanced_exa",
      "enabled": true
    }
  }
}
